{
    "compileOnSave": true,
    "compilerOptions": {
        "incremental": true,
        "sourceMap": true,
        "target": "es2015",
        "module": "es2015",
        "lib": [
            "es2015",
            "es2016",
            "es2017",
            "dom"
        ],
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,
        "moduleResolution": "bundler",
        "types": [],
        "tsBuildInfoFile": "build/.tsbuildinfo"
    },
    "include": [
        "src"
    ]
}