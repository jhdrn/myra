{
  "name": "myra",
  "private": true,
  "version": "7.1.0",
  "description": "Myra is a simple and small Typescript JSX rendering library.",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhdrn/myra.git"
  },
  "keywords": [
    "myra",
    "typescript",
    "jsx"
  ],
  "author": {
    "name": "Jonathan Hedrén",
    "email": "jonathan.hedren@gmail.com"
  },
  "bugs": {
    "url": "https://github.com/jhdrn/myra/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@types/chai": "^5.2.3",
    "@types/eslint__js": "^8.42.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.2.4",
    "@types/sinon": "^21.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "chai": "^6.2.2",
    "copyfiles": "^2.4.1",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.0.3",
    "jsdom": "^26.0.0",
    "rimraf": "^6.0.1",
    "sinon": "^21.0.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.1",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "vite build && vite build --mode minified",
    "postbuild": "dts-bundle-generator --config dts-config.json --project tsconfig.json && copyfiles LICENSE README.md package.json dist",
    "pretest": "tsc --noEmit --project tsconfig.test.json",
    "test": "vitest run",
    "test:local": "vitest",
    "bench": "vitest bench",
    "coverage": "vitest run --coverage",
    "playground": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts"
  },
  "main": "myra.cjs",
  "module": "myra.mjs",
  "typings": "myra.d.ts",
  "exports": {
    ".": {
      "types": "./myra.d.ts",
      "import": "./myra.mjs",
      "require": "./myra.cjs"
    }
  },
  "engines": {
    "node": ">=20"
  }
}